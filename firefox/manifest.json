{
  "manifest_version": 3,
  "name": "Redgifs Downloader",
  "version": "1.4",
  "description": "The button that RedGifs forgot to add.",
  "browser_specific_settings": {
    "gecko": {
      "id": "redgifs-downloader@extensiondownloader.com",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "downloads",
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.redgifs.com/*",
    "*://api.github.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.redgifs.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["mp4worker.js"],
      "matches": ["*://*.redgifs.com/*"]
    }
  ]
}